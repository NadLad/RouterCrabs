# ═══════════════════════════════════════════════════════════════
# iziRouter — Configuration multi-provider générique
# ═══════════════════════════════════════════════════════════════
#
# Chaque tier (FLASH / PRO) peut pointer vers UN fournisseur
# différent : DeepSeek, OpenAI, Groq, OpenRouter, Anthropic, etc.
#
# Format d'authentification :
#   - FLASH_AUTH_HEADER / PRO_AUTH_HEADER (défaut : "Bearer")
#   - "Bearer" → ajoute "Authorization: Bearer <key>"
#   - Autre   → ajoute "<header>: <key>" (ex: "x-api-key" pour Anthropic natif)
# ═══════════════════════════════════════════════════════════════


# ── Tier FLASH (questions simples) ────────────────────────────

FLASH_API_KEY=sk-votre-cle-flash
FLASH_API_BASE=https://api.deepseek.com
FLASH_MODEL=deepseek-v4-flash
# FLASH_AUTH_HEADER=Bearer       # optionnel (défaut)


# ── Tier PRO (questions complexes) ─────────────────────────────

PRO_API_KEY=sk-votre-cle-pro
PRO_API_BASE=https://api.deepseek.com
PRO_MODEL=deepseek-v4-pro
# PRO_AUTH_HEADER=Bearer         # optionnel (défaut)


# ── Réglages du routeur ───────────────────────────────────────

PORT=8001                        # optionnel (défaut : 8001)
COMPLEXITY_THRESHOLD=3           # optionnel (défaut : 3, plus bas = plus de requêtes vers PRO)
RUST_LOG=info,izi_router=debug   # optionnel


# ═══════════════════════════════════════════════════════════════
# Exemples de configuration par fournisseur
# ═══════════════════════════════════════════════════════════════

# ── DeepSeek (Flash + Pro) ────────────────────────────────────
# FLASH_API_KEY=sk-votre-cle-deepseek
# FLASH_API_BASE=https://api.deepseek.com
# FLASH_MODEL=deepseek-v4-flash
# PRO_API_KEY=sk-votre-cle-deepseek
# PRO_API_BASE=https://api.deepseek.com
# PRO_MODEL=deepseek-v4-pro

# ── OpenAI (GPT-4o-mini + GPT-4o) ─────────────────────────────
# FLASH_API_KEY=sk-votre-cle-openai
# FLASH_API_BASE=https://api.openai.com
# FLASH_MODEL=gpt-4o-mini
# PRO_API_KEY=sk-votre-cle-openai
# PRO_API_BASE=https://api.openai.com
# PRO_MODEL=gpt-4o

# ── Groq (Llama 8B + Llama 70B) ───────────────────────────────
# FLASH_API_KEY=gsk_votre-cle-groq
# FLASH_API_BASE=https://api.groq.com/openai
# FLASH_MODEL=llama-3.1-8b-instant
# PRO_API_KEY=gsk_votre-cle-groq
# PRO_API_BASE=https://api.groq.com/openai
# PRO_MODEL=llama-3.3-70b-versatile

# ── OpenRouter (mix de providers) ─────────────────────────────
# FLASH_API_KEY=sk-or-v1-votre-cle
# FLASH_API_BASE=https://openrouter.ai/api
# FLASH_MODEL=deepseek/deepseek-v4-flash
