# ═══════════════════════════════════════════════════════════════
# RouterCrabs — Environment Variables
# ═══════════════════════════════════════════════════════════════
#
# Tiers are configured in tiers.yaml (copy from tiers.yaml.example).
#
# API keys are referenced in tiers.yaml via ${VARIABLE_NAME}.
# Put them here to avoid hardcoding them in the YAML.

# DeepSeek (used by fallback and domain tiers)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# AgriLLM (used by the "agri" tier)
AGRI_API_KEY=your-agrillm-key

# Optional: per-tier overrides
# RESEARCH_API_KEY=...
# CODE_API_KEY=...

# Settings
TIERS_CONFIG=tiers.yaml
PORT=8001
RUST_LOG=info,router_crabs=debug
