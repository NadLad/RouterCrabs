# ═══════════════════════════════════════════════════════════════
# iziRouter — Variables d'environnement
# ═══════════════════════════════════════════════════════════════
#
# Les tiers sont configurés dans tiers.yaml (copier depuis
# tiers.yaml.example).
#
# Les clés API sont référencées dans tiers.yaml via ${NOM_VARIABLE}.
# Mets-les ici pour ne pas les hardcoder dans le YAML.

# DeepSeek (utilisé par les tiers "recherche", "code", "general")
DEEPSEEK_API_KEY=sk-votre-cle-deepseek

# AgriLLM (utilisé par le tier "agri")
AGRI_API_KEY=votre-cle-agrillm

# Facultatif : surcharges par tier
# RESEARCH_API_KEY=...
# CODE_API_KEY=...

# Réglages
TIERS_CONFIG=tiers.yaml
PORT=8001
RUST_LOG=info,izi_router=debug
