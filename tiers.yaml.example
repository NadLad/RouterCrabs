# RouterCrabs — exemple de configuration hybride
#
# Phase 1 — Mots-clés de domaine : si des mots-clés matchent → tier du domaine
# Phase 2 — Complexité : sinon, heuristiques de complexité → simple ou complex
#
# Heuristiques de complexité (score 0-12) :
#   - Longueur du prompt (>300, >800, >2000 chars)       → +1, +2, +3
#   - Présence de code (```, fn, class, SELECT…)          → +2, +3
#   - Mots-clés techniques (explique, architecture…)       → +1, +2, +3
#   - Images                                               → +5
#   - Question ouverte (? + pourquoi/comment)               → +1

port: 8001

# ── Tiers par domaine (mots-clés) ──────────────────────────
# Ajoute ici tes domaines métier. Les mots-clés sont en substring
# case-insensitive. Le score = nombre_de_matchs × weight.
# En cas d'égalité, le weight départage, puis default: true.
tiers:
  # Exemple : domaine agriculture
  # - model: "agrillm-v2"
  #   api_base: "https://api.agrillm.com/v1"
  #   api_key: "${AGRI_API_KEY}"
  #   keywords: [agriculture, agronomie, sol, plante, récolte, ferme, élevage]
  #   weight: 20

  # Exemple : domaine code
  # - model: "deepseek-v4-pro"
  #   api_base: "https://api.deepseek.com"
  #   api_key: "${DEEPSEEK_API_KEY}"
  #   keywords: [code, Rust, Python, déploiement, API, database, SQL, Docker]
  #   weight: 10

  # Fallback ultime (si ni mots-clés ni complexité configurés)
  - model: "deepseek-v4-flash"
    api_base: "https://api.deepseek.com"
    api_key: "${DEEPSEEK_API_KEY}"
    keywords: []
    default: true

# ── Routage par complexité (optionnel mais recommandé) ─────
# S'active quand aucun mot-clé de domaine ne matche.
# Décommente la section pour l'activer :
#
# fallback:
#   threshold: 3
#   simple:
#     model: "deepseek-v4-flash"
#     api_base: "https://api.deepseek.com"
#     api_key: "${DEEPSEEK_API_KEY}"
#   complex:
#     model: "deepseek-v4-pro"
#     api_base: "https://api.deepseek.com"
#     api_key: "${DEEPSEEK_API_KEY}"
