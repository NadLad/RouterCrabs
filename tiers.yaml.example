# RouterCrabs — hybrid configuration example
#
# Phase 1 — Domain keywords: if keywords match → domain tier
# Phase 2 — Complexity: otherwise, complexity heuristics → simple or complex
#
# Complexity heuristics (score 0-12):
#   - Prompt length (>300, >800, >2000 chars)          → +1, +2, +3
#   - Code presence (```, fn, class, SELECT…)            → +2, +3
#   - Technical keywords (explain, architecture…)         → +1, +2, +3
#   - Images                                              → +5
#   - Open-ended question (? + why/how)                    → +1

port: 8001

# ── Domain tiers (keywords) ──────────────────────────
# Add your business domains here. Keywords use case-insensitive
# substring matching. Score = match_count × weight.
# Ties are broken by weight, then default: true.
tiers:
  # Example: agriculture domain
  # - model: "agrillm-v2"
  #   api_base: "https://api.agrillm.com/v1"
  #   api_key: "${AGRI_API_KEY}"
  #   keywords: [agriculture, agronomy, soil, plant, harvest, farm, livestock]
  #   weight: 20

  # Example: code domain
  # - model: "deepseek-v4-pro"
  #   api_base: "https://api.deepseek.com"
  #   api_key: "${DEEPSEEK_API_KEY}"
  #   keywords: [code, Rust, Python, deployment, API, database, SQL, Docker]
  #   weight: 10

  # Ultimate fallback (if neither keywords nor complexity are configured)
  - model: "deepseek-v4-flash"
    api_base: "https://api.deepseek.com"
    api_key: "${DEEPSEEK_API_KEY}"
    keywords: []
    default: true

# ── Complexity routing (optional but recommended) ─────
# Activated when no domain keywords match.
# Uncomment the section to enable it:
#
# fallback:
#   threshold: 3
#   simple:
#     model: "deepseek-v4-flash"
#     api_base: "https://api.deepseek.com"
#     api_key: "${DEEPSEEK_API_KEY}"
#   complex:
#     model: "deepseek-v4-pro"
#     api_base: "https://api.deepseek.com"
#     api_key: "${DEEPSEEK_API_KEY}"
